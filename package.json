{
  "name": "portfolio-shirsendu",
  "version": "1.26.0",
  "description": "Shirsendu's devfolio showcasing his projects, experience and certification in a visually appealing manner",
  "author": "Shirsendu Bairagi <shirsendu2001@gmail.com>",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shba007/portfolio-shirsendu.git"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": "^22.11.0 || ^24.14.0",
    "pnpm": "^9.15.0 || ^10.2.0",
    "bun": "^1.2.9"
  },
  "packageManager": "bun@1.3.12",
  "scripts": {
    "prepare": "husky || true",
    "postinstall": "nuxt prepare",
    "dev": "nuxt dev",
    "detect": "gitleaks git --verbose",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "test:load": "k6 run tests/load.test.ts",
    "build": "nuxt build && (cp -r static .output/static || true)",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node --env-file=.env.prod .output/server/index.mjs",
    "clean": "nuxt cleanup && (cd src-tauri && cargo clean)",
    "docker:build": "docker build --build-arg VERSION=dev -t portfolio-shirsendu:dev .",
    "docker:start": "docker run --detach --name portfolio-shirsendu-dev --mount type=bind,source=$(pwd)/static,target=/app/static,readonly --env-file .env.prod -p 4100:3000 portfolio-shirsendu:dev",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:dev:mobile": "tauri android dev",
    "tauri:build:mobile": "tauri android build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.64.0",
    "@hannoeru/nuxt-otel": "^0.0.8",
    "@notionhq/client": "^5.20.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.4",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/mcp-toolkit": "^0.15.0",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@regle/nuxt": "^1.24.0",
    "@splidejs/splide-extension-grid": "^0.4.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/web-push": "^3.6.4",
    "@unhead/vue": "^2.1.13",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue-email/components": "^0.0.21",
    "@vue-email/render": "^0.0.9",
    "@vue-email/tailwind": "^0.2.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "confbox": "^0.2.4",
    "date-fns": "^4.1.0",
    "nodemailer": "^8.0.7",
    "nuxt": "^4.4.4",
    "nuxt-nodemailer": "^1.1.4",
    "nuxt-splide": "^1.1.2",
    "vue": "latest",
    "vue-router": "latest",
    "web-push": "^3.6.7",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "^1.3.13",
    "@types/k6": "^1.7.0",
    "@vue/test-utils": "^2.4.9",
    "eslint": "^10.2.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "playwright-core": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "isolated-vm",
    "protobufjs",
    "sharp",
    "unrs-resolver",
    "vue-demi"
  ]
}
